# Database
MYSQL_DEV_USER=dev_project
MYSQL_DEV_PASSWORD=dev_password_please_change
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=genesis

# JWT / OAuth Core
OAUTH_ISSUER=http://localhost:8000
OAUTH_ALGORITHM=RS256
OAUTH_DEFAULT_AUDIENCE=genesis-api
OAUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
OAUTH_REFRESH_TOKEN_TTL_DAYS=30
OAUTH_SECRET_KEY=change_me_to_a_random_hex_string

# RS256 Keys (file-based for dev)
OAUTH_PRIVATE_KEY_PATH=./secrets/dev-private.pem
OAUTH_PUBLIC_KEY_PATH=./secrets/dev-public.pem
OAUTH_JWT_KID=genesis-dev-1

# JWKS
JWKS_CACHE_TTL_SECONDS=300

# CORS (comma-separated origins)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Session Management
MAX_CONCURRENT_SESSIONS=5

# SSO Providers (Phase 5 - leave blank until configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# Storage (local or s3)
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT_URL=

# Logging
LOG_LEVEL=INFO
